# Auto detect text files and perform LF normalization
* text=auto

# Force LF line endings for all text files
* text eol=lf

# Explicitly set line endings for source files
*.sol text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.mjs text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

